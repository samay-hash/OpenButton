{
  "name": "tokokino",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "author": {
    "name": "Shiva Bhattacharjee"
  },
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "opennextjs-cloudflare build",
    "build:next": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "lint:strict": "eslint --max-warnings=0",
    "lint:fix:strict": "eslint --fix --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "test": "vitest run tests",
    "test:watch": "vitest tests",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "build:thumbs": "node scripts/build-overlay-thumbs.mjs",
    "build:backgrounds": "node scripts/build-background-thumbs.mjs"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@opennextjs/cloudflare": "^1.19.11",
    "@remixicon/react": "^4.9.0",
    "@sentry/browser": "^9.47.1",
    "@smithy/fetch-http-handler": "^5.4.3",
    "@xyflow/react": "^12.10.2",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "cloudflare": "^6.2.0",
    "clsx": "^2.1.1",
    "color": "^5.0.3",
    "date-fns": "^4.2.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "html-to-image": "^1.11.13",
    "import-in-the-middle": "^1.15.0",
    "lodash": "^4.18.1",
    "lucide-react": "^1.9.0",
    "motion": "^12.38.0",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.4",
    "react-image-crop": "^11.0.10",
    "react-infinite-scroll-component": "^7.2.0",
    "require-in-the-middle": "^7.5.2",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unique-names-generator": "^4.7.1",
    "vaul": "^1.1.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260520.1",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/color": "^4.2.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.93.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp",
      "better-sqlite3"
    ]
  }
}
